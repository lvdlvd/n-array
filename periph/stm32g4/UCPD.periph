      <field name="HRSTSENTCF" mask="0x00000040" access="wo" description="Clear hard reset sent" />
      <field name="TXUNDCF" mask="0x00000080" access="wo" description="Clear Tx underrun" />
      <field name="RXORDDETCF" mask="0x00000200" access="wo" description="Clear Rx ordered set detected" />
      <field name="RXHRSTDETCF" mask="0x00000400" access="wo" description="Clear Rx hard reset detected" />
      <field name="RXOVRCF" mask="0x00000800" access="wo" description="Clear Rx overflow" />
      <field name="RXMSGENDCF" mask="0x00001000" access="wo" description="Clear Rx message end" />
      <field name="TYPECEVT1CF" mask="0x00004000" access="wo" description="Clear Type-C event 1" />
      <field name="TYPECEVT2CF" mask="0x00008000" access="wo" description="Clear Type-C event 2" />
      <field name="FRSEVTCF" mask="0x00100000" access="wo" description="Clear FRS event" />
