      <field name="HRSTSENT" mask="0x00000040" access="rc_w1" description="Hard reset sent" />
      <field name="TXUND" mask="0x00000080" access="rc_w1" description="Tx data underrun" />
      <field name="RXNE" mask="0x00000100" access="ro" description="Rx not empty" />
      <field name="RXORDDET" mask="0x00000200" access="rc_w1" description="Rx ordered set detected" />
      <field name="RXHRSTDET" mask="0x00000400" access="rc_w1" description="Rx hard reset detected" />
      <field name="RXOVR" mask="0x00000800" access="rc_w1" description="Rx overflow" />
      <field name="RXMSGEND" mask="0x00001000" access="rc_w1" description="Rx message end" />
      <field name="RXERR" mask="0x00002000" access="rc_w1" description="Rx error" />
      <field name="TYPECEVT1" mask="0x00004000" access="rc_w1" description="Type-C event 1" />
      <field name="TYPECEVT2" mask="0x00008000" access="rc_w1" description="Type-C event 2" />
      <field name="TYPEC_VSTATE_CC1" mask="0x00030000" access="ro" description="CC1 voltage level" />
      <field name="TYPEC_VSTATE_CC2" mask="0x000C0000" access="ro" description="CC2 voltage level" />
      <field name="FRSEVT" mask="0x00100000" access="rc_w1" description="FRS event" />
    </register>
    
    <register name="ICR" offset="0x18" reset="0x00000000" access="wo" description="Interrupt clear register">
      <field name="TXMSGDISCCF" mask="0x00000002" access="wo" description="Clear Tx message discarded" />
      <field name="TXMSGSENTCF" mask="0x00000004" access="wo" description="Clear Tx message sent" />
      <field name="TXMSGABTCF" mask="0x00000008" access="wo" description="Clear Tx message abort" />
