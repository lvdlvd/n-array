<!--
  STM32G4 UCPD (USB Type-C Power Delivery) Peripheral
  Extracted from RM0440 Rev 7
-->
<device name="STM32G4" reference_manual="RM0440" revision="7">
  
  <peripheral name="UCPD" description="USB Type-C Power Delivery">
    <instance id="1" base="0x4000A000" />
    
    <register name="CFG1" offset="0x00" reset="0x00000000" description="Configuration register 1">
      <field name="HBITCLKDIV" mask="0x0000003F" access="rw" description="Half-bit clock divider" />
      <field name="IFRGAP" mask="0x000007C0" access="rw" description="Interframe gap" />
      <field name="TRANSWIN" mask="0x0000F800" access="rw" description="Transition window duration" />
      <field name="PSC_USBPDCLK" mask="0x000E0000" access="rw" description="Pre-scaler for UCPD_CLK" />
      <field name="RXORDSETEN" mask="0x1FF00000" access="rw" description="Rx ordered set enable" />
      <field name="TXDMAEN" mask="0x20000000" access="rw" description="Tx DMA enable" />
      <field name="RXDMAEN" mask="0x40000000" access="rw" description="Rx DMA enable" />
      <field name="UCPDEN" mask="0x80000000" access="rw" description="UCPD peripheral enable" />
    </register>
    
    <register name="CFG2" offset="0x04" reset="0x00000000" description="Configuration register 2">
      <field name="RXFILTDIS" mask="0x00000001" access="rw" description="BMC decoder Rx pre-filter disable" />
      <field name="RXFILT2N3" mask="0x00000002" access="rw" description="BMC decoder Rx pre-filter config" />
      <field name="FORCECLK" mask="0x00000004" access="rw" description="Force clock enable" />
      <field name="WUPEN" mask="0x00000008" access="rw" description="Wakeup/general purpose timer enable" />
    </register>
    
    <register name="CR" offset="0x0C" reset="0x00000000" description="Control register">
      <field name="TXMODE" mask="0x00000003" access="rw" description="Tx mode">
        <enum value="0x00000000" name="HardReset" />
        <enum value="0x00000001" name="CableReset" />
        <enum value="0x00000002" name="BIST" />
      </field>
      <field name="TXSEND" mask="0x00000004" access="rs" description="Start transmission" />
      <field name="TXHRST" mask="0x00000008" access="rs" description="Transmit hard reset" />
      <field name="RXMODE" mask="0x00000010" access="rw" description="Rx mode" />
      <field name="PHYRXEN" mask="0x00000020" access="rw" description="Phy Rx enable" />
      <field name="PHYCCSEL" mask="0x00000040" access="rw" description="CC1/CC2 line selection for Rx/Tx" />
      <field name="ANASUBMODE" mask="0x00000180" access="rw" description="Analog PHY sub-mode" />
      <field name="ANAMODE" mask="0x00000200" access="rw" description="Analog PHY mode" />
      <field name="CCENABLE" mask="0x00000C00" access="rw" description="CC line enable" />
      <field name="FRSRXEN" mask="0x00010000" access="rw" description="FRS Rx enable" />
      <field name="FRSTX" mask="0x00020000" access="rs" description="FRS transmit" />
      <field name="RDCH" mask="0x00040000" access="rw" description="Rd/Rd on CC1/CC2" />
      <field name="CC1TCDIS" mask="0x00100000" access="rw" description="CC1 type-C disable" />
      <field name="CC2TCDIS" mask="0x00200000" access="rw" description="CC2 type-C disable" />
    </register>
    
    <register name="IMR" offset="0x10" reset="0x00000000" description="Interrupt mask register">
      <field name="TXISIE" mask="0x00000001" access="rw" description="Tx interrupt status IE" />
      <field name="TXMSGDISCIE" mask="0x00000002" access="rw" description="Tx message discarded IE" />
      <field name="TXMSGSENTIE" mask="0x00000004" access="rw" description="Tx message sent IE" />
      <field name="TXMSGABTIE" mask="0x00000008" access="rw" description="Tx message abort IE" />
      <field name="HABORTSTIE" mask="0x00000010" access="rw" description="Hard reset abort IE" />
      <field name="HRSTDISCIE" mask="0x00000020" access="rw" description="Hard reset discarded IE" />
      <field name="HRSTSENTIE" mask="0x00000040" access="rw" description="Hard reset sent IE" />
      <field name="TXUNDIE" mask="0x00000080" access="rw" description="Tx underrun IE" />
      <field name="RXNEIE" mask="0x00000100" access="rw" description="Rx not empty IE" />
      <field name="RXORDDETIE" mask="0x00000200" access="rw" description="Rx ordered set detect IE" />
      <field name="RXHRSTDETIE" mask="0x00000400" access="rw" description="Rx hard reset detect IE" />
      <field name="RXOVRIE" mask="0x00000800" access="rw" description="Rx overflow IE" />
      <field name="RXMSGENDIE" mask="0x00001000" access="rw" description="Rx message end IE" />
      <field name="TYPECEVT1IE" mask="0x00004000" access="rw" description="Type-C event 1 IE" />
      <field name="TYPECEVT2IE" mask="0x00008000" access="rw" description="Type-C event 2 IE" />
      <field name="FRSEVTIE" mask="0x00100000" access="rw" description="FRS event IE" />
    </register>
    
    <register name="SR" offset="0x14" reset="0x00000000" description="Status register">
      <field name="TXIS" mask="0x00000001" access="ro" description="Tx interrupt status" />
