      <af num="15" func="EVENTOUT" />
    </pin>
    
    <pin name="PA10">
      <af num="0" func="TIM17_BKIN" />
      <af num="1" func="TIM1_CH3" />
      <af num="2" func="TIM2_CH4" />
      <af num="3" func="HRTIM1_CHB1" cat="4" />
      <af num="5" func="SPI2_MISO" />
