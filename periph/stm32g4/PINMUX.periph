      <af num="15" func="EVENTOUT" />
    </pin>
    
    <pin name="PA11">
      <af num="1" func="TIM1_CH4" />
      <af num="2" func="TIM1_CH1N" />
      <af num="3" func="HRTIM1_CHB2" cat="4" />
      <af num="4" func="TIM4_CH1" />
      <af num="5" func="SPI2_MOSI" />
      <af num="6" func="TIM1_BKIN2" />
