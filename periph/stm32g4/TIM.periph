      <field name="BKINP" mask="0x00000200" access="rw" description="BKIN input polarity" />
      <field name="BKCMP1P" mask="0x00000400" access="rw" description="COMP1 break input polarity" />
      <field name="BKCMP2P" mask="0x00000800" access="rw" description="COMP2 break input polarity" />
    </register>
    
    <register name="TISEL" offset="0x68" reset="0x00000000" description="Timer input selection register">
      <field name="TI1SEL" mask="0x0000000F" access="rw" description="TI1 input selection" />
    </register>
    
  </peripheral>
  
</device>
