# [N]Array CORDIC example — Nucleo-G474RE.
# Runs the cordic-math deterministic vector sweep on silicon and prints the
# records over USART2 for diffing against the host emulation.

# Nucleo-G474RE: STM32G474RET6 (LQFP64, 512K flash, Cat4), ROM run model.
PART      = STM32G474
PARTFULL  = STM32G474RET6
MEMTARGET = STM32G474Exx_ROM

LIB    = ../../lib
PERIPH = ../../periph/stm32g4
NARRAY = ../../gen/narray

PREFIX  = arm-none-eabi-
CC      = $(PREFIX)gcc
OBJCOPY = $(PREFIX)objcopy
SIZE    = $(PREFIX)size

ARCH    = -mcpu=cortex-m4 -mthumb -mfloat-abi=hard -mfpu=fpv4-sp-d16
# CORDIC math correctness: no builtin math, no FMA contraction, no fast-math
# (so the compiler emits real calls and the low bits match the host model).
MATH    = -fno-builtin -ffp-contract=off
CFLAGS  = -std=gnu23 -O2 -g3 -ffreestanding -ffunction-sections -fdata-sections \
          $(ARCH) $(MATH) -DCM_DUMP_NO_MAIN -Wall -Wextra -Wno-pedantic -I. -I$(LIB)
LDFLAGS = -nostartfiles -lnosys $(ARCH) -T $(MEMTARGET).ld -Wl,-L,. -Wl,-L,$(LIB) \
          -Wl,--gc-sections,-Map,cordic.map

CSRC = main.c device_dump.c \
       $(LIB)/cordic_math.c $(LIB)/cordic_stm32.c \
       $(LIB)/gpio.c $(LIB)/clock.c $(LIB)/tprintf.c $(LIB)/fault.c

# generated by narray (delete to regenerate)
GEN = device.h pinmux.h devs.ld $(MEMTARGET).ld

$(NARRAY): $(wildcard ../../gen/*.go)
	cd ../../gen && go build -o narray .

device.h: $(NARRAY)
	$(NARRAY) -part $(PART) -header $(PERIPH) > $@

pinmux.h: $(NARRAY)
	$(NARRAY) -pinmux $(PERIPH) > $@

devs.ld: $(NARRAY)
	$(NARRAY) -part $(PART) -devs $(PERIPH) > $@

$(MEMTARGET).ld: $(NARRAY)
	$(NARRAY) -memory $(MEMTARGET) $(PERIPH) > $@

cordic.elf: $(GEN) $(CSRC) $(LIB)/sections.ld
	$(CC) $(CFLAGS) $(CSRC) $(LDFLAGS) -o $@
	$(SIZE) $@

cordic.bin: cordic.elf
	$(OBJCOPY) -O binary $< $@

.DEFAULT_GOAL := cordic.bin

# regenerate the in-file pinout annotations from the datasheet
pinfmt: $(NARRAY) pinmux.h
	$(NARRAY) -part $(PARTFULL) -pinfmt main.c $(PERIPH)

flash: cordic.bin
	st-flash --reset write cordic.bin 0x08000000

clean:
	rm -f *.o *.elf *.bin *.hex *.map $(GEN)

.PHONY: flash clean pinfmt
